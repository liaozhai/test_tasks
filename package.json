{
    "name": "parallel_tasks",
    "packageManager": "yarn@4.17.0",
    "devDependencies": {
        "@types/geojson": "^7946.0.16",
        "@types/node": "^26.0.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.4",
        "protobufjs": "^8.6.5",
        "protobufjs-cli": "^2.5.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "build": "tsc",
        "dev:serve": "nodemon --inspect src/server.ts",
        "dev:data": "nodemon --inspect src/data.ts",
        "data": "tsx src/data.ts",
        "serve": "tsx src/server.ts",
        "proto": "npx pbjs --ts src/feature.ts proto/feature.proto"
    },
    "dependencies": {
        "@fastify/multipart": "^10.0.0",
        "fastify": "^5.8.5",
        "fastify-plugin": "^6.0.0",
        "form-data": "^4.0.6"
    }
}
