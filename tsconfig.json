{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "types": ["node"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "moduleResolution": "nodenext",
        "allowJs": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
