{
    "compilerOptions": {
        "target": "es2020",
        "module": "node20",
        "types": ["node"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "allowJs": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
